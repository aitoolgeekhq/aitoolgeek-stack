# Internal reverse proxy. TLS is terminated upstream (e.g. Cloudflare Tunnel),
# so Caddy listens on :80 and routes by Host header.
#
# X-Forwarded-Proto is forced to "https" on all upstreams so apps like Ghost
# don't redirect-loop back to HTTPS.
#
# Hosts come from env vars — set them in docker-compose.yml / .env.

{
	admin off
	auto_https off
}

(upstream-https) {
	header_up X-Forwarded-Proto https
	header_up X-Forwarded-Host {host}
}

:80 {
	@ghost host {$GHOST_DOMAIN} www.{$GHOST_DOMAIN}
	handle @ghost {
		# Plausible first-party proxy (bypasses ad-blockers that match /js/script.*.js).
		@plausible_js path /js/sc.js
		handle @plausible_js {
			rewrite * /js/script.file-downloads.hash.outbound-links.pageview-props.tagged-events.js
			reverse_proxy plausible:8000 {
				header_up Host {$PLAUSIBLE_DOMAIN}
				header_up X-Forwarded-Proto https
			}
		}
		@plausible_event path /api/event
		handle @plausible_event {
			reverse_proxy plausible:8000 {
				header_up Host {$PLAUSIBLE_DOMAIN}
				header_up X-Forwarded-Proto https
			}
		}

		handle {
			reverse_proxy ghost:2368 {
				import upstream-https
			}
		}
	}

	@n8n host {$N8N_DOMAIN}
	handle @n8n {
		reverse_proxy n8n:5678 {
			import upstream-https
		}
	}

	@plausible host {$PLAUSIBLE_DOMAIN}
	handle @plausible {
		reverse_proxy plausible:8000 {
			import upstream-https
		}
	}

	@uptime host {$UPTIME_DOMAIN}
	handle @uptime {
		reverse_proxy uptime:3001 {
			import upstream-https
		}
	}

	handle {
		respond "unknown host" 404
	}
}
