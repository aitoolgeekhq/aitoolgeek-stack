# ===== AI Tool Geek — stack env =====
# Copy to `.env` and fill in. Generate passwords with:
#   openssl rand -base64 32
#
# All domains below point to THIS container via your Cloudflare Tunnel.
# You'll configure the tunnel routes separately (see ../cloudflared/config.example.yml).

# ---------------- Domains ----------------
GHOST_DOMAIN=aitoolgeek.ai
N8N_DOMAIN=n8n.aitoolgeek.ai
PLAUSIBLE_DOMAIN=stats.aitoolgeek.ai
UPTIME_DOMAIN=status.aitoolgeek.ai

# ---------------- Timezone ----------------
TZ=Asia/Dubai

# ---------------- Ghost MySQL ----------------
GHOST_DB_PASSWORD=CHANGE_ME_ghost_db_pw
GHOST_DB_ROOT_PASSWORD=CHANGE_ME_mysql_root_pw

# ---------------- Shared Postgres ----------------
POSTGRES_ROOT_PASSWORD=CHANGE_ME_pg_root_pw
POSTGRES_N8N_PASSWORD=CHANGE_ME_n8n_pg_pw
POSTGRES_PLAUSIBLE_PASSWORD=CHANGE_ME_plausible_pg_pw

# ---------------- n8n ----------------
# 32-char random hex. Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_32_char_hex_key

# ---------------- Plausible ----------------
# 64-char base64. Generate: openssl rand -base64 48
PLAUSIBLE_SECRET_KEY_BASE=CHANGE_ME_plausible_key_base

# ---------------- Outbound email (for Ghost newsletter) ----------------
# Pick ONE. Recommended: Resend (https://resend.com) — 3k free/month.
# Alternative: SES, Postmark, Sendgrid, Mailgun.
MAIL_SERVICE=
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USER=resend
MAIL_PASSWORD=CHANGE_ME_smtp_password
MAIL_FROM=hello@aitoolgeek.ai
