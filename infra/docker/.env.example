# Copy to `.env` and fill in.
#
# Generate passwords with:
#   openssl rand -base64 32   # DB passwords
#   openssl rand -hex 32      # N8N_ENCRYPTION_KEY
#   openssl rand -base64 48   # PLAUSIBLE_SECRET_KEY_BASE

# ---------- Domains ----------
# These must match what your Cloudflare Tunnel (or whatever public-facing proxy you use) forwards here.
GHOST_DOMAIN=YOURDOMAIN.com
N8N_DOMAIN=n8n.YOURDOMAIN.com
PLAUSIBLE_DOMAIN=stats.YOURDOMAIN.com
UPTIME_DOMAIN=status.YOURDOMAIN.com

# ---------- Timezone ----------
TZ=UTC

# ---------- Ghost (MySQL) ----------
GHOST_DB_PASSWORD=CHANGE_ME
GHOST_DB_ROOT_PASSWORD=CHANGE_ME

# ---------- Shared Postgres (n8n + Plausible) ----------
POSTGRES_ROOT_PASSWORD=CHANGE_ME
POSTGRES_N8N_PASSWORD=CHANGE_ME
POSTGRES_PLAUSIBLE_PASSWORD=CHANGE_ME

# ---------- n8n ----------
N8N_ENCRYPTION_KEY=CHANGE_ME_32_char_hex

# ---------- Plausible ----------
PLAUSIBLE_SECRET_KEY_BASE=CHANGE_ME_48_byte_base64

# ---------- Outbound email (Ghost newsletter) ----------
# Pick any SMTP provider: Resend, SES, Postmark, Sendgrid, Mailgun...
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USER=resend
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=hello@YOURDOMAIN.com
